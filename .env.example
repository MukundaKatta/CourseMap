# CourseMap Configuration
# Copy this file to .env and adjust values as needed.

# Logging level: DEBUG, INFO, WARNING, ERROR
COURSEMAP_LOG_LEVEL=INFO

# Maximum number of recommendations to return (default: 10)
COURSEMAP_MAX_RECOMMENDATIONS=10

# Minimum relevance score threshold (0.0 - 1.0)
COURSEMAP_MIN_SCORE=0.1

# Default export format: json, csv, markdown
COURSEMAP_EXPORT_FORMAT=json

# Course catalog file path (optional, for loading from file)
COURSEMAP_CATALOG_PATH=
